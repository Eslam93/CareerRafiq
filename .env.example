PORT=8787
NODE_ENV=development
CAREERRAFIQ_START_API=1

# Origins
CAREERRAFIQ_WEB_ORIGIN=http://localhost:5173
CAREERRAFIQ_EXTENSION_ORIGIN=
CAREERRAFIQ_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:8787

# Persistence
CAREERRAFIQ_DATA_DIR=./apps/api/data
CAREERRAFIQ_DB_FILE=./apps/api/data/career-rafiq.db
CAREERRAFIQ_UPLOADS_DIR=./apps/api/data/uploads
CAREERRAFIQ_WEB_DIST_DIR=./apps/web/dist

# Upload validation
CAREERRAFIQ_MAX_CV_UPLOAD_COUNT=5
CAREERRAFIQ_MAX_CV_UPLOAD_BYTES=8388608
CAREERRAFIQ_UPLOAD_RATE_LIMIT_MAX=6
CAREERRAFIQ_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=300
CAREERRAFIQ_CAPTURE_RATE_LIMIT_MAX=30
CAREERRAFIQ_CAPTURE_RATE_LIMIT_WINDOW_SECONDS=60

# Cookies
CAREERRAFIQ_INSECURE_DEV_COOKIE=1

# Operator diagnostics
CAREERRAFIQ_ENABLE_EYE_MODE=0
CAREERRAFIQ_OPERATOR_EMAILS=
CAREERRAFIQ_EYE_RETENTION_DAYS=7

# Email transport
CAREERRAFIQ_EMAIL_FROM=no-reply@example.com
CAREERRAFIQ_MAGIC_LINK_THROTTLE_SECONDS=60
CAREERRAFIQ_DEV_AUTO_VERIFY_MAGIC_LINK=0
CAREERRAFIQ_SMTP_HOST=
CAREERRAFIQ_SMTP_PORT=587
CAREERRAFIQ_SMTP_SECURE=0
CAREERRAFIQ_SMTP_USER=
CAREERRAFIQ_SMTP_PASSWORD=

# AI feature flags
CAREERRAFIQ_ENABLE_AI_SETUP_SUGGESTIONS=1
CAREERRAFIQ_ENABLE_AI_EXTRACTION_FALLBACK=1
CAREERRAFIQ_ENABLE_AI_SIGNAL_INFERENCE=1
CAREERRAFIQ_ENABLE_AI_CONSENSUS=0
OPENAI_API_KEY=
CAREERRAFIQ_OPENAI_MODEL=gpt-5-mini
CAREERRAFIQ_OPENAI_BASE_URL=https://api.openai.com/v1
CAREERRAFIQ_OPENAI_TIMEOUT_MS=45000
